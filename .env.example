# ---- Feedback system configuration ----
# Copy this file to ".env" and edit. All values are optional except ADMIN_PASSWORD.

# Password for the dashboard at "/". CHANGE THIS before going live.
ADMIN_PASSWORD=changeme

# Public URL where this server is reached. Used for the Secure cookie flag and
# the startup log. Set to your real https URL in production.
PUBLIC_URL=https://fb.mysite.co

# Port to listen on.
PORT=3000

# Optional: restrict which site origins may submit feedback (comma-separated).
# Leave empty to accept submissions from any site (normal for a public widget).
# Example: https://site-a.com,https://site-b.com
ALLOWED_ORIGINS=

# Optional: secret used to sign the admin login cookie. If omitted it is derived
# from ADMIN_PASSWORD (changing the password logs everyone out). Set a fixed
# random string if you want sessions to survive password changes.
SESSION_SECRET=

# Max request body size (screenshots are sent inline). Default 25mb.
MAX_BODY=25mb
